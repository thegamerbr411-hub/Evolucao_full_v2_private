{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/auth/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/workouts/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/nutrition/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/sync/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/social/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/ranking/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/subscription/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/health",
      "dest": "backend/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "backend/server.js"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "ENABLE_QA_LOCAL_BYPASS": "0"
  }
}
