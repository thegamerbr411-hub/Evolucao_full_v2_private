{
  "name": "evolucao_full_v2",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "start:android:stable": "powershell -ExecutionPolicy Bypass -File scripts/start-expo-android-stable.ps1",
    "backend": "npm --prefix backend run start",
    "dashboard": "npm --prefix dashboard run start",
    "test:basic": "node scripts/test-basic.js",
    "start:tunnel": "expo start --tunnel",
    "start:dev-client": "expo start --dev-client",
    "start:dev-client:tunnel": "expo start --dev-client --tunnel",
    "start:rn": "react-native start",
    "android": "expo run:android",
    "release:apk": "powershell -ExecutionPolicy Bypass -File scripts/release-local-install.ps1 -NoInstall",
    "release:install": "powershell -ExecutionPolicy Bypass -File scripts/release-local-install.ps1",
    "android:rn": "react-native run-android",
    "android:fix-run": "powershell -ExecutionPolicy Bypass -File scripts/fix-and-run-android.ps1",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "node scripts/run-node-tests.js",
    "test:all": "node scripts/run-node-tests.js && node dashboard/tests/api.test.js && node scripts/test-flow.js",
    "fix:java": "powershell -ExecutionPolicy Bypass -File scripts/fix-java.ps1",
    "fix:adb": "powershell -ExecutionPolicy Bypass -File scripts/fix-adb.ps1",
    "dev:start": "powershell -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "dashboard:start": "node dashboard/server.js",
    "qa:smoke": "node scripts/test-flow.js",
    "dashboard:test": "node dashboard/tests/api.test.js",
    "dashboard:analyze": "node dashboard/scripts/ai-analyze.js",
    "qa:night": "node dashboard/scripts/night-run.js",
    "detox:build": "detox build --configuration android.emulator.debug",
    "detox:build:attached": "detox build --configuration android.attached.debug",
    "detox:test": "node scripts/run-detox-with-config.js emulator",
    "detox:test:attached": "node scripts/run-detox-with-config.js attached",
    "detox:test:attached:release": "detox test --configuration android.attached.release",
    "detox:auto": "powershell -ExecutionPolicy Bypass -File scripts/detox-bootstrap.ps1 -Mode auto -Run cycle",
    "detox:auto:test": "powershell -ExecutionPolicy Bypass -File scripts/detox-bootstrap.ps1 -Mode auto -Run test",
    "detox:cycle": "node scripts/run-detox-cycle.js",
    "detox:loop": "node scripts/run-detox-loop.js",
    "qa:soak:2h": "powershell -ExecutionPolicy Bypass -File scripts/run-detox-loop.ps1 -Hours 2 -CooldownMs 15000 -Configuration android.attached.debug",
    "qa:optional:detox": "npm run detox:test:attached",
    "qa:optional:visual": "npm run qa:full:visual:quick",
    "qa:optional:stress": "npm run qa:stress:ux:10m",
    "qa:optional:night": "npm run qa:night:once",
    "qa:phase4:run": "powershell -ExecutionPolicy Bypass -File scripts/qa_phase4/run_phase4_hardening.ps1",
    "qa:phase4:analyze": "node scripts/qa_phase4/analyze_phase4_results.js",
    "qa:stress:ux": "node scripts/ux-stress-loop.js",
    "qa:stress:ux:10m": "node scripts/ux-stress-loop.js --duration-ms=600000",
    "qa:stress:ux:1h": "node scripts/ux-stress-loop.js --duration-ms=3600000",
    "qa:stress:ux:15m": "node scripts/ux-stress-loop.js --duration-ms=900000",
    "qa:night:once": "node dashboard/scripts/night-run.js --once",
    "test:auto": "node scripts/test-flow.js",
    "qa:prod:check": "node scripts/validate-production.js",
    "qa:full:visual": "node scripts/full-visual-qa.js",
    "qa:full:visual:quick": "node scripts/full-visual-qa.js --cycles=1 --stability-cycles=1 --mobile-only",
    "qa:full:global": "powershell -ExecutionPolicy Bypass -File scripts/full-visual-qa-global.ps1",
    "qa:global:audit": "powershell -ExecutionPolicy Bypass -File scripts/qa-global-audit-loop.ps1 -Profile standard",
    "qa:global:audit:quick": "powershell -ExecutionPolicy Bypass -File scripts/qa-global-audit-loop.ps1 -Profile quick",
    "qa:global:audit:attached:strict": "powershell -ExecutionPolicy Bypass -File scripts/qa-global-audit-loop.ps1 -Profile attached-strict",
    "qa:mobile:observability": "node scripts/mobile-observability-baseline.js",
    "qa:mobile:observability:enforce": "powershell -Command \"$env:MOBILE_SLO_ENFORCE='1'; node scripts/mobile-observability-baseline.js\"",
    "rollback:auto:slo": "node scripts/rollback.js --auto-slo",
    "audit:release:check": "node scripts/sync-audit-release.js check",
    "audit:release:sync": "node scripts/sync-audit-release.js sync",
    "qa:visual:audit": "powershell -ExecutionPolicy Bypass -File scripts/visual-audit-loop.ps1 -Cycles 1",
    "qa:visual:audit:5x": "powershell -ExecutionPolicy Bypass -File scripts/visual-audit-loop.ps1 -Cycles 5",
    "qa:controlled": "node qa/core/run-controlled-cycle.js",
    "qa:controlled:3x": "node qa/core/run-controlled-cycle.js --cycles=3",
    "qa:controlled:help": "node qa/core/run-controlled-cycle.js --help",
    "sim:loop": "node scripts/user-simulation-loop.js",
    "sim:generate": "node scripts/ai-generate-tests.js",
    "ai:brain": "node scripts/ai-brain.js",
    "ai:brain:loop": "node scripts/ai-brain-loop.js",
    "growth:review": "node scripts/growth-go-no-go.js",
    "alerts": "node scripts/alerts.js",
    "continuous:runner": "node scripts/continuous-runner.js",
    "rollback": "node scripts/rollback.js",
    "qa:cleanup": "powershell -ExecutionPolicy Bypass -File scripts/qa-cleanup.ps1"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.0",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@types/react": "~19.2.10",
    "axios": "^1.15.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "expo": "~55.0.15",
    "expo-auth-session": "~55.0.14",
    "expo-av": "^16.0.8",
    "expo-clipboard": "~55.0.13",
    "expo-haptics": "~55.0.14",
    "expo-image-picker": "~55.0.18",
    "expo-modules-core": "~55.0.22",
    "expo-notifications": "~55.0.19",
    "expo-secure-store": "^55.0.13",
    "expo-web-browser": "~55.0.14",
    "express": "^4.22.1",
    "firebase": "^12.11.0",
    "jsonwebtoken": "^9.0.3",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-mmkv": "^4.3.1",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "^0.7.4",
    "typescript": "~5.9.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@react-native-community/cli": "^20.1.3",
    "@react-native/metro-config": "^0.83.4",
    "@types/jest": "^29.5.14",
    "detox": "^20.39.0",
    "jest": "~29.7.0",
    "playwright": "^1.59.1"
  }
}
