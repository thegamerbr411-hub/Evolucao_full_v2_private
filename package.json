{
  "name": "evolucao_full_v2",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "node --test __tests__/*.test.mjs",
    "test:e2e": "detox test --configuration android.attached",
    "test:stress": "npm run test:e2e && npm run test:e2e && npm run test:e2e",
    "build:e2e": "detox build --configuration android.attached",
    "soak:android": "powershell -ExecutionPolicy Bypass -File scripts/soak-android.ps1 -DurationMinutes 120 -EventsPerIteration 220 -ThrottleMs 80"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "expo": "~55.0.11",
    "expo-haptics": "^55.0.11",
    "expo-image-picker": "^55.0.16",
    "expo-notifications": "~55.0.16",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "detox": "^20.50.1",
    "jest": "^30.3.0",
    "jest-circus": "^30.3.0"
  }
}
