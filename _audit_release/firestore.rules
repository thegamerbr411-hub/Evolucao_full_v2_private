// firestore.rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Beta feedback collection rules
    match /betaFeedback/{feedbackId} {
      // Allow read if user is the owner
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      
      // Allow create if user is authenticated
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      
      // Allow update if user is the owner or admin
      allow update: if request.auth != null && 
        (request.auth.uid == resource.data.userId || 
         request.auth.token.admin == true);
      
      // Allow delete if user is the owner or admin
      allow delete: if request.auth != null && 
        (request.auth.uid == resource.data.userId || 
         request.auth.token.admin == true);
    }
    
    // Beta feedback list (admin only)
    match /betaFeedback {
      allow list: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
