{
  "root": {
    "name": "evolucao_full_v2",
    "scripts": {
      "validation": ["test", "test:all", "dashboard:test", "qa:smoke"],
      "ops": ["dashboard:start", "qa:night", "qa:prod:check", "continuous:runner"],
      "ai": ["ai:brain", "ai:brain:loop", "alerts", "rollback"],
      "detox": ["detox:build", "detox:test:attached", "detox:test:attached:release", "detox:auto"]
    },
    "deps_runtime": [
      "expo", "react", "react-native", "axios", "firebase", "express", "jsonwebtoken"
    ]
  },
  "dashboard": {
    "scripts": [
      "start",
      "start:worker",
      "start:worker:ai",
      "start:worker:fix",
      "start:worker:retest",
      "test"
    ],
    "deps": ["express", "cors", "dotenv", "jsonwebtoken", "bullmq", "ioredis"]
  },
  "render": {
    "services": [
      "evolucao-api",
      "evolucao-worker-ai",
      "evolucao-worker-fix",
      "evolucao-worker-retest",
      "evolucao-redis"
    ]
  }
}
