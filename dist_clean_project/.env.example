# App / API base
EXPO_PUBLIC_API_BASE_URL=https://evolucao-api-dou2.onrender.com
EXPO_PUBLIC_QA_API_BASE_URL=https://evolucao-api-dou2.onrender.com
EXPO_PUBLIC_QA_CLIENT_ID=admin
EXPO_PUBLIC_QA_API_KEY=replace_with_app_api_key
EXPO_PUBLIC_APP_VERSION=1.0.3

# Google OAuth (Expo Auth Session)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=replace_with_android_client_id
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=replace_with_expo_client_id
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=replace_with_ios_client_id

# Dashboard / backend (local)
ADMIN_USER=admin
ADMIN_PASS=change_this_password
JWT_SECRET=change_this_secret
DEFAULT_CLIENT_ID=admin
CLIENT_API_KEYS={"admin":"replace_with_client_api_key"}
APP_API_KEY=replace_with_app_api_key
ENABLE_QA_LOCAL_BYPASS=0
