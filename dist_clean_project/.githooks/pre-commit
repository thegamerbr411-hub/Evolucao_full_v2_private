#!/usr/bin/env bash

max_size=$((5 * 1024 * 1024))
failed=0

while IFS= read -r -d '' file; do
  case "$file" in
    *.apk|*.zip)
      echo "[pre-commit] bloqueado: arquivo proibido $file"
      failed=1
      continue
      ;;
  esac

  size=$(git cat-file -s ":$file" 2>/dev/null)
  if [ -n "$size" ] && [ "$size" -gt "$max_size" ]; then
    echo "[pre-commit] bloqueado: $file maior que 5MB ($size bytes)"
    failed=1
  fi
done < <(git diff --cached --name-only -z)

if [ "$failed" -ne 0 ]; then
  echo "[pre-commit] commit cancelado por politica de tamanho/artefato"
  exit 1
fi

exit 0
